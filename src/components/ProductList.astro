---
/**
 * ProductList.astro
 *
 * Simula la lógica de obtener datos desde un Google Sheet publicado como JSON.
 * En producción reemplazá el import por un fetch a tu Sheet:
 *
 *   const res = await fetch('https://docs.google.com/spreadsheets/d/{ID}/gviz/tq?tqx=out:json');
 */

interface Producto {
  nombre: string;
  precio: number;
}

interface Categoria {
  categoria: string;
  emoji: string;
  productos: Producto[];
}

let categorias: Categoria[] = [];
let fetchError = false;

try {
  const raw = await import('../../public/data/products.json');
  categorias = raw.default as Categoria[];
} catch (e) {
  console.error('Error cargando productos:', e);
  fetchError = true;
}

const formatPrecio = (n: number) =>
  new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 0 }).format(n);
---

<section id="catalogo" class="px-6 py-12">
  <h2 class="text-primary text-2xl font-extrabold mb-8 text-center font-headline">
    Lista de Precios Mayoristas ✨
  </h2>

  {fetchError && (
    <div class="bg-error/20 border border-error/40 rounded-lg p-4 text-center text-error text-sm mb-6">
      No se pudieron cargar los productos. Contactanos por WhatsApp.
    </div>
  )}

  <!-- Grid de categorías tipo tarjeta de producto -->
  <div class="space-y-6 max-w-lg mx-auto mb-10">
    {categorias.map((cat) => (
      <div class="bg-surface-container rounded-lg overflow-hidden shadow-md">

        <!-- Header de categoría -->
        <div class="flex items-center gap-3 px-5 py-3.5
                    bg-surface-container-high border-b border-outline-variant">
          <span class="text-2xl" aria-hidden="true">{cat.emoji}</span>
          <h3 class="font-bold text-on-surface text-lg font-headline flex-1">{cat.categoria}</h3>
          <span class="bg-primary/20 text-primary text-xs font-semibold
                       px-2.5 py-0.5 rounded-full border border-primary/30">
            {cat.productos.length}
          </span>
        </div>

        <!-- Lista de productos -->
        <ul class="divide-y divide-outline-variant/50">
          {cat.productos.map((prod, i) => (
            <li class="flex items-center justify-between px-5 py-3 gap-3
                       hover:bg-surface-container-high/60 transition-colors">
              <div class="flex items-center gap-2.5 min-w-0">
                <span class="flex-shrink-0 w-5 h-5 rounded-full
                             bg-primary/15 border border-primary/25
                             text-primary text-[10px] font-bold
                             flex items-center justify-center tabular-nums">
                  {i + 1}
                </span>
                <span class="text-on-surface-variant text-sm leading-snug truncate">{prod.nombre}</span>
              </div>
              <span class="flex-shrink-0 text-primary font-bold text-base tabular-nums">
                {formatPrecio(prod.precio)}
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Botón descargar PDF (placeholder) -->
  <a
    href="#"
    class="block w-full py-5 px-6 max-w-lg mx-auto
           bg-surface-container-highest border border-outline-variant
           text-primary font-bold text-center rounded-lg shadow-lg
           active:scale-95 transition-transform"
  >
    📑 Descargar Lista de Precios Completa (PDF)
  </a>

  <p class="text-center text-on-surface-variant/50 text-xs mt-4 max-w-xs mx-auto">
    * Precios mayoristas. Sujetos a cambio sin previo aviso.
  </p>
</section>
