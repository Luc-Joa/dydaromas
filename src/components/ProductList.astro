---
/**
 * ProductList.astro
 *
 * Simula la lógica de obtener datos desde un Google Sheet publicado como JSON.
 * En producción, reemplazá DATA_URL con la URL real de tu Google Sheet:
 *
 *   const DATA_URL =
 *     'https://sheets.googleapis.com/v4/spreadsheets/{ID}/values/{RANGE}?key={API_KEY}';
 *
 * O bien usando la exportación CSV pública:
 *   const DATA_URL =
 *     'https://docs.google.com/spreadsheets/d/{ID}/gviz/tq?tqx=out:json';
 *
 * Por ahora usamos el archivo JSON local en /public/data/products.json
 */

interface Producto {
  nombre: string;
  precio: number;
}

interface Categoria {
  categoria: string;
  emoji: string;
  productos: Producto[];
}

// ── Simulated fetch (como si viniera de Google Sheets) ──────────────────────
const DATA_URL = '/data/products.json';

let categorias: Categoria[] = [];
let fetchError = false;

try {
  // En SSR/build time, Astro puede hacer fetch a assets locales
  const baseUrl = import.meta.env.PROD
    ? 'https://localhost' // reemplazá con tu dominio en producción
    : 'http://localhost:4321';

  // Para el build/dev local usamos import directo (más confiable en Astro static)
  const raw = await import('../../public/data/products.json');
  categorias = raw.default as Categoria[];
} catch (e) {
  console.error('Error cargando productos:', e);
  fetchError = true;
}

// Formateador de precios ARS
const formatPrecio = (n: number) =>
  new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    minimumFractionDigits: 0,
  }).format(n);
---

<section id="catalogo" class="px-4 py-8">
  <!-- Título de sección -->
  <div class="text-center mb-8">
    <span
      class="inline-block bg-brand-orange/20 text-brand-orange text-xs font-semibold tracking-widest uppercase px-4 py-1.5 rounded-full mb-3 border border-brand-orange/30"
    >
      Lista de Precios
    </span>
    <h2 class="text-2xl font-bold text-white">
      Catálogo Mayorista
    </h2>
    <p class="text-blue-200 text-sm mt-1">
      Precios vigentes · Actualizados periódicamente
    </p>
  </div>

  {fetchError && (
    <div class="bg-red-500/20 border border-red-400/40 rounded-2xl p-4 text-center text-red-200 text-sm">
      No se pudieron cargar los productos. Contactanos por WhatsApp.
    </div>
  )}

  {!fetchError && categorias.length === 0 && (
    <div class="text-center text-blue-200 py-8">Cargando catálogo...</div>
  )}

  <!-- Categorías -->
  <div class="space-y-6 max-w-lg mx-auto">
    {categorias.map((cat) => (
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl overflow-hidden shadow-card">
        <!-- Header de categoría -->
        <div class="flex items-center gap-3 px-5 py-3.5 bg-brand-orange/15 border-b border-white/10">
          <span class="text-2xl" aria-hidden="true">{cat.emoji}</span>
          <h3 class="font-bold text-white text-lg tracking-tight">{cat.categoria}</h3>
          <span class="ml-auto bg-brand-orange/25 text-brand-orange text-xs font-semibold px-2.5 py-0.5 rounded-full border border-brand-orange/30">
            {cat.productos.length} productos
          </span>
        </div>

        <!-- Lista de productos -->
        <ul class="divide-y divide-white/5">
          {cat.productos.map((prod, i) => (
            <li class="flex items-center justify-between px-5 py-3 gap-3 hover:bg-white/5 transition-colors">
              <div class="flex items-center gap-2.5 min-w-0">
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-brand-orange/20 border border-brand-orange/30 text-brand-orange text-[10px] font-bold flex items-center justify-center">
                  {i + 1}
                </span>
                <span class="text-blue-100 text-sm leading-snug truncate">{prod.nombre}</span>
              </div>
              <span class="flex-shrink-0 text-brand-orange font-bold text-base tabular-nums">
                {formatPrecio(prod.precio)}
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Nota al pie del catálogo -->
  <p class="text-center text-blue-300 text-xs mt-6 max-w-xs mx-auto">
    * Precios mayoristas. IVA incluido. Sujetos a cambio sin previo aviso.
  </p>
</section>
