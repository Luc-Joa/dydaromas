---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'D y D Aromas | Distribuidores Mayoristas Saphirus',
  description = 'Reventa de productos Saphirus desde Concordia, Entre Ríos. Velas, sahumerios, difusores y más. Envíos Andreani a todo el país.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <style>
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #00529b;
      }
      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #003d74;
      }
      ::-webkit-scrollbar-thumb {
        background: #f18a22;
        border-radius: 3px;
      }
    </style>
  </head>
  <body class="min-h-screen bg-brand-blue text-white antialiased">
    <slot />
  </body>
</html>
