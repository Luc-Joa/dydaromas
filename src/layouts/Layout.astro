---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DyD Aromas | Distribuidores Mayoristas Saphirus',
  description = 'Reventa de productos Saphirus. Envíos a todo el país.',
} = Astro.props;
---

<!DOCTYPE html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!--
      ┌─────────────────────────────────────────────────────┐
      │  FUENTES LOCALES — sin Google Fonts CDN              │
      │  Elimina 2 round-trips bloqueantes al render        │
      │  Archivos en public/fonts/ (woff2, latin only)      │
      └─────────────────────────────────────────────────────┘
    -->

    <!-- Preload de fuentes críticas (body font primero, headline font segundo) -->
    <link
      rel="preload"
      href="/fonts/manrope-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/plus-jakarta-sans-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <style>
      /* ── Fuentes locales ── */
      @font-face {
        font-family: 'Manrope';
        font-style: normal;
        font-weight: 400 600;   /* variable range: cubre 400, 500, 600 */
        font-display: swap;     /* evita FOIT — texto visible de inmediato */
        src: url('/fonts/manrope-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6,
                       U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F,
                       U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215,
                       U+FEFF, U+FFFD;
      }

      @font-face {
        font-family: 'Plus Jakarta Sans';
        font-style: normal;
        font-weight: 700 800;   /* variable range: cubre 700 y 800 */
        font-display: swap;
        src: url('/fonts/plus-jakarta-sans-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6,
                       U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F,
                       U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215,
                       U+FEFF, U+FFFD;
      }

      /* ── Base ── */
      html { scroll-behavior: smooth; }

      body {
        font-family: 'Manrope', system-ui, sans-serif;
        background-color: #0a2a5e;
        color: #e8f0ff;
        min-height: 100dvh;
      }

      h1, h2, h3 {
        font-family: 'Plus Jakarta Sans', sans-serif;
        letter-spacing: -0.02em;
      }

      /* ── Glassmorphism nav ── */
      .glass-nav {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
      }

      /* ── Scrollbar personalizada ── */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #061d4a; }
      ::-webkit-scrollbar-thumb { background: #ffb77d; border-radius: 3px; }
    </style>
  </head>
  <body class="bg-surface text-on-surface antialiased">
    <slot />
  </body>
</html>
