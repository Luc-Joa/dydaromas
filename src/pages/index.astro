---
import Layout from '../layouts/Layout.astro';
import ProductList from '../components/ProductList.astro';
import MapPin from '@lucide/astro/icons/map-pin';
import Truck from '@lucide/astro/icons/truck';
import ShoppingBag from '@lucide/astro/icons/shopping-bag';
import Star from '@lucide/astro/icons/star';
import Phone from '@lucide/astro/icons/phone';
import MessageCircle from '@lucide/astro/icons/message-circle';
import Music from '@lucide/astro/icons/music';

const WA_NUMBER = '5493456000000'; // Reemplazá con el número real (sin + ni espacios)
const WA_MESSAGE = encodeURIComponent(
  'Hola, vi la info en la web y quiero mi primer pedido de $60k'
);
const WA_URL = `https://wa.me/${WA_NUMBER}?text=${WA_MESSAGE}`;
---

<Layout>
  <div class="min-h-screen bg-brand-blue">

    <!-- ═══════════════════════════════════════════
         HEADER / HERO
    ═══════════════════════════════════════════ -->
    <header class="relative overflow-hidden">
      <!-- Fondo degradado decorativo -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-brand-blue-dark via-brand-blue to-brand-blue-light opacity-80"
        aria-hidden="true"
      ></div>
      <!-- Círculos decorativos de fondo -->
      <div
        class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-brand-orange/10 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-white/5 blur-2xl"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 flex flex-col items-center px-4 pt-10 pb-8">
        <!-- Logo principal -->
        <div class="relative mb-4">
          <div class="w-40 h-40 rounded-3xl overflow-hidden shadow-card-lg border-4 border-white/20 bg-white/10">
            <img
              src="/Logo + Punto de venta oficial + Dirección.jpeg"
              alt="D y D Aromas - Punto de Venta Oficial Saphirus"
              class="w-full h-full object-contain p-2"
              loading="eager"
            />
          </div>
          <!-- Badge Punto de Venta Oficial -->
          <div class="absolute -bottom-3 -right-3 bg-brand-orange text-white text-[10px] font-bold px-2.5 py-1 rounded-full shadow-lg flex items-center gap-1 whitespace-nowrap">
            <Star class="w-3 h-3 fill-white" />
            Oficial Saphirus
          </div>
        </div>

        <!-- Nombre y tagline -->
        <h1 class="text-3xl font-extrabold text-white text-center tracking-tight mt-4 drop-shadow-lg">
          D y D Aromas
        </h1>
        <p class="text-brand-orange font-semibold text-sm mt-1 tracking-wide text-center">
          Distribuidores Mayoristas · Saphirus
        </p>

        <!-- Ubicación -->
        <div class="flex items-center gap-1.5 mt-3 text-blue-200 text-xs">
          <MapPin class="w-3.5 h-3.5 text-brand-orange flex-shrink-0" />
          <span>Concordia, Entre Ríos · Envíos a todo el país</span>
        </div>

        <!-- Foto local -->
        <div class="mt-6 w-full max-w-sm rounded-3xl overflow-hidden shadow-card-lg border border-white/10">
          <img
            src="/Foto local desde fuera.jpeg"
            alt="Local D y D Aromas"
            class="w-full h-48 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </header>

    <!-- ═══════════════════════════════════════════
         MENSAJE DE BIENVENIDA
    ═══════════════════════════════════════════ -->
    <section class="px-4 py-6">
      <div class="max-w-lg mx-auto bg-white/5 border border-white/10 rounded-3xl p-5 shadow-card">
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-10 h-10 rounded-2xl bg-brand-orange/20 border border-brand-orange/30 flex items-center justify-center">
            <MessageCircle class="w-5 h-5 text-brand-orange" />
          </div>
          <div>
            <p class="text-white font-semibold text-sm mb-1">Mensaje de bienvenida</p>
            <p class="text-blue-100 text-sm leading-relaxed">
              Hola, realizamos ventas <strong class="text-white">Mayoristas / Minoristas</strong> de productos
              <strong class="text-brand-orange">Saphirus</strong>.
            </p>
            <p class="text-blue-100 text-sm leading-relaxed mt-2">
              Somos de Concordia, Entre Ríos pero hacemos envíos a todo el país por
              <strong class="text-white">Andreani 🇦🇷📦🚚</strong>
            </p>
            <p class="text-blue-100 text-sm leading-relaxed mt-2">
              El único requisito es realizar una
              <strong class="text-brand-orange">compra mínima de $60.000</strong> para
              comenzar como Revendedor/a. Dentro de esa compra podés elegir lo que quieras y
              ya te quedan los precios por MAYOR.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         AUDIO PLAYER (Mensaje de Bienvenida)
    ═══════════════════════════════════════════ -->
    <section class="px-4 pb-6">
      <div
        class="max-w-lg mx-auto bg-gradient-to-r from-brand-orange/20 to-brand-blue-light/30 border border-brand-orange/30 rounded-3xl p-5 shadow-card"
        id="audio-player-section"
      >
        <div class="flex items-center gap-4">
          <!-- Onda decorativa animada -->
          <div class="flex-shrink-0 relative">
            <div class="w-14 h-14 rounded-2xl bg-brand-orange flex items-center justify-center shadow-lg" id="play-btn" style="cursor:pointer">
              <Music class="w-6 h-6 text-white" id="music-icon" />
            </div>
          </div>

          <div class="flex-1 min-w-0">
            <p class="text-white font-bold text-sm">Mensaje de Bienvenida</p>
            <p class="text-blue-200 text-xs mt-0.5">D y D Aromas · Saphirus</p>

            <!-- Barra de progreso visual (decorativa) -->
            <div class="mt-2.5 h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div
                class="h-full bg-brand-orange rounded-full transition-all duration-300"
                id="progress-bar"
                style="width: 0%"
              ></div>
            </div>
            <div class="flex justify-between text-blue-300 text-[10px] mt-1">
              <span id="current-time">0:00</span>
              <span id="total-time">--:--</span>
            </div>
          </div>

          <!-- Controles de volumen simplificado -->
          <div class="flex-shrink-0 flex flex-col items-center gap-1">
            <button
              id="mute-btn"
              class="w-8 h-8 rounded-xl bg-white/10 hover:bg-white/20 transition-colors flex items-center justify-center"
              aria-label="Silenciar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Audio HTML5 oculto -->
        <audio id="welcome-audio" class="hidden" preload="none">
          <!-- Reemplazá /audio/bienvenida.mp3 con tu archivo real -->
          <source src="/audio/bienvenida.mp3" type="audio/mpeg" />
          Tu navegador no soporta audio HTML5.
        </audio>

        <p class="text-blue-300/60 text-[10px] text-center mt-3">
          Colocá tu archivo de audio en <code class="bg-white/10 px-1 rounded">public/audio/bienvenida.mp3</code>
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         CONDICIONES MAYORISTAS (Cards)
    ═══════════════════════════════════════════ -->
    <section id="condiciones" class="px-4 pb-8">
      <div class="text-center mb-6">
        <span
          class="inline-block bg-brand-orange/20 text-brand-orange text-xs font-semibold tracking-widest uppercase px-4 py-1.5 rounded-full border border-brand-orange/30"
        >
          Reglas Mayoristas
        </span>
        <h2 class="text-2xl font-bold text-white mt-2">
          Cómo Funciona
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-4 max-w-lg mx-auto">

        <!-- Card 1: Compra Inicial -->
        <div class="group relative bg-gradient-to-br from-brand-orange to-orange-500 rounded-3xl p-5 shadow-card-lg overflow-hidden">
          <div class="absolute top-0 right-0 w-24 h-24 rounded-full bg-white/10 -translate-y-6 translate-x-6" aria-hidden="true"></div>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-2xl bg-white/20 flex items-center justify-center">
                <ShoppingBag class="w-5 h-5 text-white" />
              </div>
              <span class="text-white/80 text-xs font-semibold uppercase tracking-wider">Compra Inicial</span>
            </div>
            <p class="text-white text-3xl font-extrabold">$60.000</p>
            <p class="text-white/80 text-xs mt-1 leading-relaxed">
              Armá tu primer pedido combinando los productos que quieras. A partir de ahí, precio mayorista permanente.
            </p>
          </div>
        </div>

        <!-- Card 2: Mantenimiento -->
        <div class="relative bg-white/5 border border-white/10 rounded-3xl p-5 shadow-card overflow-hidden">
          <div class="absolute top-0 right-0 w-20 h-20 rounded-full bg-brand-orange/10 -translate-y-4 translate-x-4" aria-hidden="true"></div>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-2xl bg-brand-orange/20 border border-brand-orange/30 flex items-center justify-center">
                <Star class="w-5 h-5 text-brand-orange" />
              </div>
              <span class="text-blue-300 text-xs font-semibold uppercase tracking-wider">Mantenimiento</span>
            </div>
            <p class="text-brand-orange text-3xl font-extrabold">$20.000</p>
            <p class="text-blue-200 text-xs mt-1 leading-relaxed">
              Monto mínimo por pedido luego de registrarte como revendedor/a. Sin vencimientos ni cuotas fijas.
            </p>
          </div>
        </div>

        <!-- Card 3: Envíos -->
        <div class="relative bg-white/5 border border-white/10 rounded-3xl p-5 shadow-card overflow-hidden">
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-2xl bg-blue-400/20 border border-blue-400/30 flex items-center justify-center">
                <Truck class="w-5 h-5 text-blue-300" />
              </div>
              <span class="text-blue-300 text-xs font-semibold uppercase tracking-wider">Envíos</span>
            </div>
            <p class="text-white text-xl font-bold">Andreani</p>
            <p class="text-brand-orange font-semibold text-sm">A todo el país 🇦🇷</p>
            <p class="text-blue-200 text-xs mt-1 leading-relaxed">
              Realizamos envíos desde Concordia, Entre Ríos. Coordinamos el despacho una vez confirmado el pedido.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         CATÁLOGO DE PRODUCTOS (componente)
    ═══════════════════════════════════════════ -->
    <ProductList />

    <!-- ═══════════════════════════════════════════
         FOOTER CON MAPA
    ═══════════════════════════════════════════ -->
    <footer class="px-4 pb-24 pt-8">
      <div class="max-w-lg mx-auto">

        <!-- Título footer -->
        <div class="text-center mb-6">
          <span
            class="inline-block bg-white/10 text-blue-200 text-xs font-semibold tracking-widest uppercase px-4 py-1.5 rounded-full border border-white/10"
          >
            Encontranos
          </span>
          <h2 class="text-xl font-bold text-white mt-2">Nuestra Ubicación</h2>
          <p class="text-blue-200 text-sm">Concordia, Entre Ríos</p>
        </div>

        <!-- Mapa embebido -->
        <div class="rounded-3xl overflow-hidden shadow-card-lg border border-white/10 mb-6 aspect-video">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d111024.82773959048!2d-58.11204!3d-31.39264!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b5ca7da9a14dcb%3A0x9b4ef36ba6975fe7!2sConcordia%2C%20Entre%20R%C3%ADos!5e0!3m2!1ses-419!2sar!4v1710000000000"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación D y D Aromas - Concordia, Entre Ríos"
          ></iframe>
        </div>

        <!-- Info de contacto -->
        <div class="bg-white/5 border border-white/10 rounded-3xl p-5 space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-xl bg-green-500/20 flex items-center justify-center">
              <Phone class="w-4 h-4 text-green-400" />
            </div>
            <div>
              <p class="text-white text-sm font-semibold">WhatsApp</p>
              <p class="text-blue-200 text-xs">Consultas y pedidos</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-xl bg-brand-orange/20 flex items-center justify-center">
              <MapPin class="w-4 h-4 text-brand-orange" />
            </div>
            <div>
              <p class="text-white text-sm font-semibold">Concordia, Entre Ríos</p>
              <p class="text-blue-200 text-xs">Despacho desde acá · Andreani</p>
            </div>
          </div>
        </div>

        <!-- Copyright -->
        <p class="text-center text-blue-400/60 text-xs mt-6">
          © 2024 D y D Aromas · Distribuidores Saphirus
        </p>
      </div>
    </footer>

    <!-- ═══════════════════════════════════════════
         BOTÓN FLOTANTE DE WHATSAPP
    ═══════════════════════════════════════════ -->
    <a
      href={WA_URL}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-6 right-4 z-50 flex items-center gap-2.5 bg-green-500 hover:bg-green-400 active:bg-green-600 text-white font-bold text-sm px-5 py-3.5 rounded-full shadow-2xl transition-all duration-200 hover:scale-105 active:scale-95"
    >
      <!-- WhatsApp icon SVG inline -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-5 h-5 flex-shrink-0"
        aria-hidden="true"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
        />
      </svg>
      <span>Hacer mi pedido</span>
    </a>

  </div>
</Layout>

<!-- ═══════════════════════════════════════════
     AUDIO PLAYER LOGIC (client-side)
═══════════════════════════════════════════ -->
<script>
  const audio = document.getElementById('welcome-audio') as HTMLAudioElement | null;
  const playBtn = document.getElementById('play-btn');
  const musicIcon = document.getElementById('music-icon');
  const progressBar = document.getElementById('progress-bar');
  const currentTimeEl = document.getElementById('current-time');
  const totalTimeEl = document.getElementById('total-time');
  const muteBtn = document.getElementById('mute-btn');

  let isPlaying = false;

  function formatTime(s: number) {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }

  if (audio && playBtn) {
    // Actualizar duración
    audio.addEventListener('loadedmetadata', () => {
      if (totalTimeEl) totalTimeEl.textContent = formatTime(audio.duration);
    });

    // Actualizar progreso
    audio.addEventListener('timeupdate', () => {
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      if (progressBar) progressBar.style.width = pct + '%';
      if (currentTimeEl) currentTimeEl.textContent = formatTime(audio.currentTime);
    });

    // Fin de reproducción
    audio.addEventListener('ended', () => {
      isPlaying = false;
      if (playBtn) playBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>`;
      if (progressBar) progressBar.style.width = '0%';
    });

    // Click en play
    playBtn.addEventListener('click', () => {
      if (isPlaying) {
        audio.pause();
        isPlaying = false;
        playBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>`;
      } else {
        audio.play().catch(() => {
          // El archivo de audio aún no existe; mostramos aviso silencioso
          console.info('Audio no disponible aún. Agregá el archivo en public/audio/bienvenida.mp3');
        });
        isPlaying = true;
        playBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
      }
    });

    // Mute
    if (muteBtn) {
      muteBtn.addEventListener('click', () => {
        audio.muted = !audio.muted;
      });
    }
  }
</script>
