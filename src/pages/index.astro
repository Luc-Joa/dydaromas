---
import Layout from '../layouts/Layout.astro';
import ProductList from '../components/ProductList.astro';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.jpg';
import heroImg from '../assets/foto-hero.jpg';
import localImg from '../assets/foto-local.jpg';

const WA_NUMBER  = '5493454928564';
const WA_MESSAGE = encodeURIComponent('Hola, vi la info en la web y quiero realizar mi primer pedido mayorista');
const WA_URL     = `https://wa.me/${WA_NUMBER}?text=${WA_MESSAGE}`;
const WA_CATALOG = 'https://wa.me/c/5493454928564';

const year = new Date().getFullYear();
---

<Layout>
  <div class="min-h-screen pb-24">

    <!-- ════════════════════════════════════════
         TOP NAV (fixed, glassmorphism)
    ════════════════════════════════════════ -->
    <nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 h-16
                bg-surface-container-low/90 glass-nav shadow-sm
                border-b border-outline-variant">
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-full bg-primary-container overflow-hidden flex-shrink-0">
          <Image
            src={logoImg}
            alt="Logo DyD Aromas"
            class="w-full h-full object-cover"
            width={72}
            height={72}
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <span class="text-lg font-bold text-secondary font-headline">DyD Aromas</span>
      </div>

      <!-- Botones derecha: WhatsApp siempre visible + audio solo cuando se cierra el bar -->
      <div class="flex items-center gap-4">
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contactar por WhatsApp"
          class="flex-shrink-0 w-9 h-9 rounded-full bg-[#25D366] flex items-center justify-center
                 active:scale-95 transition-transform hover:scale-105 shadow-md"
        >
          <!-- SVG WhatsApp inline (sin dependencia externa) -->
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <!-- Botón de audio — visible solo cuando el audio-bar está cerrado -->
        <button
          id="nav-audio-btn"
          aria-label="Reproducir audio de bienvenida"
          class="hidden flex-shrink-0 w-9 h-9 rounded-full bg-primary flex items-center justify-center
                 hover:bg-primary/80 transition-colors active:scale-95 shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-on-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- ════════════════════════════════════════
         MAIN CONTENT
    ════════════════════════════════════════ -->
    <main class="relative pt-16 overflow-x-hidden">

      <span class="absolute pointer-events-none select-none opacity-80
                   text-primary text-4xl bottom-1/4 -left-2 rotate-[25deg]"
            aria-hidden="true">🦋</span>

      <!-- ── HERO ── -->
      <section class="relative px-6 py-12 flex flex-col items-center text-center">
        <div class="mb-8 w-full max-w-sm aspect-video rounded-lg overflow-hidden shadow-2xl
                    border-2 border-surface-container-high relative">
          <Image
            src={heroImg}
            alt="Local DyD Aromas - Concordia, Entre Ríos"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            width={384}
            height={216}
          />
          <div class="absolute inset-0 from-surface via-transparent to-transparent opacity-60"></div>
        </div>

        <h1 class="text-primary text-3xl md:text-5xl font-extrabold mb-4 leading-tight font-headline">
          <span class="block text-on-surface text-xl md:text-2xl font-semibold mt-1">
            Concordia, Entre Ríos
          </span>
        </h1>
        <p class="text-on-surface-variant text-lg font-medium max-w-xs md:max-w-md">
          Envíos a todo el país por Andreani 🇦🇷📦🚚
        </p>

        <div class="mt-8 flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-1 w-12 bg-primary rounded-full"></div>
          </div>
        </div>
      </section>

      <!-- ── BENEFICIOS MAYORISTAS ── -->
      <section class="px-6 py-12 bg-surface-container-low rounded-t-lg relative z-10">
        <h2 class="text-primary text-2xl font-extrabold mb-8 text-center font-headline">
          Beneficios Exclusivos para Mayoristas ✨
        </h2>
        <div class="grid gap-6 max-w-lg mx-auto">

          <!-- Card 1: Compra inicial -->
          <div class="bg-surface-container-high p-6 rounded-lg border-l-4 border-primary shadow-sm">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">🛍️</span>
              <div>
                <h3 class="text-on-surface font-bold text-lg mb-1 font-headline">
                  Primera Compra Mínima: $60.000
                </h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">
                  Armá tu pedido inicial a tu gusto con toda nuestra variedad de productos.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 2: Reposición -->
          <div class="bg-surface-container-high p-6 rounded-lg border-l-4 border-secondary shadow-sm">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">✳️</span>
              <div>
                <h3 class="text-on-surface font-bold text-lg mb-1 font-headline">
                  Siguientes Compras: Mínimo $20.000
                </h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">
                  Mantené tu precio mayorista con pedidos de reposición más accesibles.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 3: Envíos -->
          <div class="bg-surface-container-high p-6 rounded-lg border-l-4 border-primary shadow-sm">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">🚚</span>
              <div>
                <h3 class="text-on-surface font-bold text-lg mb-1 font-headline">
                  Envíos a todo el país por Andreani
                </h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">
                  Si sos de Concordia escribinos por WhatsApp para coordinar.
                </p>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── CTA SECTION ── -->
      <section class="px-6 py-12 mx-4 mb-8 mt-8 bg-primary-container rounded-lg">
        <h2 class="text-on-primary-container text-2xl font-black mb-6 text-center font-headline">
          ¡Emprendé con nosotros!
        </h2>
        <div class="flex flex-col gap-4 max-w-sm mx-auto">
          <a
            href={WA_CATALOG}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full py-4
                   bg-on-surface text-surface font-extrabold rounded-full shadow-xl
                   active:scale-95 transition-transform"
          >
            <svg viewBox="0 0 24 24" class="w-5 h-5 flex-shrink-0" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Ver Catálogo en WhatsApp
          </a>
          <a
            href={WA_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full py-4
                   bg-surface text-primary font-extrabold rounded-full shadow-xl
                   border-2 border-primary active:scale-95 transition-transform"
          >
            <span class="text-2xl" aria-hidden="true">📱</span> ¡Quiero info!
          </a>
        </div>
      </section>

      <!-- ── CONTACTO Y UBICACIÓN ── -->
      <section class="px-6 py-12 bg-surface-container-lowest" id="contacto">
        <h2 class="text-primary text-2xl font-bold mb-8 text-center font-headline">
          Ubicación y Datos de Contacto 📍
        </h2>

        <div class="space-y-6 mb-8 max-w-lg mx-auto">

          <!-- Dirección — icono SVG inline (reemplaza material-symbols-outlined) -->
          <div class="flex items-center gap-4">
            <!-- location_on (Material Symbols) → SVG inline equivalente -->
            <svg class="w-6 h-6 flex-shrink-0 text-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <a href="https://maps.app.goo.gl/HMdARP5uSi28qa5Z8"
               target="_blank" rel="noopener noreferrer"
               class="hover:text-primary transition-colors">
              <p class="text-on-surface font-semibold">Las Heras 680</p>
              <p class="text-on-surface-variant text-sm">Concordia, Entre Ríos</p>
            </a>
          </div>

          <!-- WhatsApp -->
          <div class="flex items-center gap-4">
            <svg class="w-6 h-6 flex-shrink-0 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <a href={WA_URL} target="_blank" rel="noopener noreferrer"
               class="text-on-surface font-semibold hover:text-primary transition-colors">
              +54 9 345 492-8564
            </a>
          </div>

          <!-- Facebook -->
          <div class="flex items-center gap-4">
            <svg class="w-6 h-6 flex-shrink-0 text-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
            <a href="https://www.facebook.com/Saphirus.DyD.Aromas"
               target="_blank" rel="noopener noreferrer"
               class="text-on-surface font-semibold hover:text-primary transition-colors">
              DyD.Aromas
            </a>
          </div>

          <!-- Instagram -->
          <div class="flex items-center gap-4">
            <svg class="w-6 h-6 flex-shrink-0 text-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            <a href="https://www.instagram.com/dyd.aromas/"
               target="_blank" rel="noopener noreferrer"
               class="text-on-surface font-semibold hover:text-primary transition-colors">
              dyd.aromas
            </a>
          </div>

          <!-- TikTok -->
          <div class="flex items-center gap-4">
            <svg class="w-6 h-6 flex-shrink-0 text-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.88a8.2 8.2 0 004.79 1.53V7a4.85 4.85 0 01-1.02-.31z"/>
            </svg>
            <a href="https://www.tiktok.com/@dyd.aromas"
               target="_blank" rel="noopener noreferrer"
               class="text-on-surface font-semibold hover:text-primary transition-colors">
              dyd.aromas
            </a>
          </div>
        </div>

        <!-- Mapa — link directo + foto del local con lazy loading -->
        <a
          href="https://maps.app.goo.gl/HMdARP5uSi28qa5Z8"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full rounded-lg overflow-hidden border border-outline-variant shadow-lg mb-8 max-w-lg mx-auto
                 hover:opacity-90 transition-opacity"
        >
          <div class="flex items-center justify-center gap-3 w-full py-5
                      bg-surface-container-high text-on-surface font-semibold">
            <!-- map icon → SVG inline -->
            <svg class="w-6 h-6 flex-shrink-0 text-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.5 3l-.16.03L15 5.1 9 3 3.36 4.9c-.21.07-.36.25-.36.48V20.5c0 .28.22.5.5.5l.16-.03L9 18.9l6 2.1 5.64-1.9c.21-.07.36-.25.36-.48V3.5c0-.28-.22-.5-.5-.5zM15 19l-6-2.11V5l6 2.11V19z"/>
            </svg>
            Ver en Google Maps
            <!-- open_in_new icon → SVG inline -->
            <svg class="w-4 h-4 flex-shrink-0 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/>
            </svg>
          </div>
          <div class="w-full aspect-video overflow-hidden border-t border-outline-variant">
            <Image
              src={localImg}
              alt="Frente del local DyD Aromas - Las Heras 680, Concordia"
              class="w-full h-full object-cover"
              loading="lazy"
              width={512}
              height={288}
            />
          </div>
        </a>

        <p class="text-on-surface-variant/50 text-xs text-center">
          © {year} DyD Aromas · Distribuidores Saphirus
        </p>
      </section>

    </main>

    <!-- ════════════════════════════════════════
         AUDIO PLAYER STICKY BOTTOM
         preload="none" — no consume ancho de banda hasta que el usuario lo inicia
    ════════════════════════════════════════ -->
    <div id="audio-bar"
         class="fixed bottom-20 left-0 right-0 z-40 px-4 transition-all duration-500
                translate-y-0 opacity-100"
    >
      <div class="max-w-lg mx-auto bg-white border border-gray-200
                  rounded-xl p-4 shadow-2xl">

        <!-- Mensaje llamativo — aparece a los 3 segundos -->
        <div id="audio-cta-msg"
             class="hidden mb-3 text-center font-extrabold text-sm font-headline
                    animate-pulse px-2 py-1.5 rounded-lg border border-orange-300
                    bg-orange-50 text-orange-700">
          🎧 ¡Reproducí el audio con nuestra explicación!
        </div>

        <div class="flex items-center gap-3">
          <button
            id="play-btn"
            class="flex-shrink-0 w-12 h-12 rounded-lg bg-primary flex items-center justify-center
                   shadow-lg active:scale-95 transition-transform cursor-pointer"
            aria-label="Reproducir mensaje de bienvenida"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-on-primary" viewBox="0 0 24 24" fill="currentColor" id="play-icon" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>

          <div class="flex-1 min-w-0">
            <p class="text-gray-900 font-bold text-xs font-headline leading-none">Mensaje de Bienvenida</p>
            <p class="text-gray-500 text-[10px] mt-0.5">DyD Aromas</p>
            <div class="mt-1.5 h-2 bg-gray-200 rounded-full overflow-hidden cursor-pointer" id="progress-track">
              <div class="h-full bg-primary rounded-full transition-all duration-300" id="progress-bar" style="width:0%"></div>
            </div>
            <div class="flex justify-between text-gray-400 text-[10px] mt-0.5">
              <span id="current-time">0:00</span>
              <span id="total-time">0:40</span>
            </div>
          </div>

          <button id="speed-btn"
            class="flex-shrink-0 w-10 h-8 rounded-full bg-gray-100 hover:bg-gray-200
                   transition-colors flex items-center justify-center
                   text-gray-600 font-bold text-xs"
            aria-label="Velocidad de reproducción">
            <span id="speed-label">1x</span>
          </button>

          <!-- close icon → SVG inline (reemplaza material-symbols-outlined) -->
          <button id="close-audio-btn"
            class="flex-shrink-0 w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200
                   transition-colors flex items-center justify-center"
            aria-label="Cerrar player">
            <svg class="w-4 h-4 text-gray-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
          </button>
        </div>

        <audio id="welcome-audio" class="hidden" preload="none">
          <source src="/audio/bienvenida.mp3" type="audio/mpeg" />
        </audio>
      </div>
    </div>

  </div>
</Layout>

<!-- ════════════════════════════════════════
     AUDIO PLAYER LOGIC
════════════════════════════════════════ -->
<script>
  const audio        = document.getElementById('welcome-audio') as HTMLAudioElement | null;
  const playBtn      = document.getElementById('play-btn');
  const playIcon     = document.getElementById('play-icon');
  const progressBar  = document.getElementById('progress-bar');
  const progressTrack = document.getElementById('progress-track');
  const currentEl    = document.getElementById('current-time');
  const totalEl      = document.getElementById('total-time');
  const speedBtn     = document.getElementById('speed-btn');
  const speedLabel   = document.getElementById('speed-label');
  const closeBtn     = document.getElementById('close-audio-btn');
  const audioBar     = document.getElementById('audio-bar');
  const navAudioBtn  = document.getElementById('nav-audio-btn');
  const audioCta     = document.getElementById('audio-cta-msg');

  const ICON_PLAY  = `<path d="M8 5v14l11-7z"/>`;
  const ICON_PAUSE = `<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>`;

  let playing  = false;
  let barClosed = false;

  const fmt = (s: number) =>
    `${Math.floor(s / 60)}:${String(Math.floor(s % 60)).padStart(2, '0')}`;

  // Mostrar CTA a los 3s, ocultar a los 13s
  setTimeout(() => {
    if (audioCta && !barClosed) {
      audioCta.classList.remove('hidden');
      setTimeout(() => audioCta.classList.add('hidden'), 10000);
    }
  }, 3000);

  if (audio && playBtn && playIcon) {
    audio.addEventListener('loadedmetadata', () => {
      if (totalEl) totalEl.textContent = fmt(audio.duration);
    });
    audio.addEventListener('timeupdate', () => {
      const p = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      if (progressBar) progressBar.style.width = p + '%';
      if (currentEl) currentEl.textContent = fmt(audio.currentTime);
    });
    audio.addEventListener('ended', () => {
      playing = false;
      playIcon.innerHTML = ICON_PLAY;
      if (progressBar) progressBar.style.width = '0%';
    });

    playBtn.addEventListener('click', () => {
      if (playing) {
        audio.pause();
        playing = false;
        playIcon.innerHTML = ICON_PLAY;
      } else {
        if (audio.ended || audio.currentTime >= audio.duration - 0.1) {
          audio.currentTime = 0;
        }
        audio.play().catch(() =>
          console.info('Agregá el audio en public/audio/bienvenida.mp3')
        );
        playing = true;
        playIcon.innerHTML = ICON_PAUSE;
      }
    });

    // Velocidad: 1x → 1.5x → 2x → 1x
    const speeds = [1, 1.5, 2];
    let speedIdx = 0;
    speedBtn?.addEventListener('click', () => {
      speedIdx = (speedIdx + 1) % speeds.length;
      audio.playbackRate = speeds[speedIdx];
      if (speedLabel) speedLabel.textContent = speeds[speedIdx] + 'x';
    });

    // Click en la barra para saltar a cualquier punto
    progressTrack?.addEventListener('click', (e) => {
      const rect = (progressTrack as HTMLElement).getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      const dur = audio.duration || 40;
      audio.currentTime = ratio * dur;
      if (!playing) {
        audio.play().catch(() => {});
        playing = true;
        playIcon.innerHTML = ICON_PAUSE;
      }
    });
  }

  // Botón cerrar: oculta el player y muestra el botón de nav
  closeBtn?.addEventListener('click', () => {
    if (audio && playing) { audio.pause(); playing = false; }
    if (audioBar) {
      audioBar.style.transform = 'translateY(120%)';
      audioBar.style.opacity = '0';
    }
    barClosed = true;
    navAudioBtn?.classList.remove('hidden');
  });

  // Botón nav: reabre el player y reproduce
  navAudioBtn?.addEventListener('click', () => {
    if (audioBar) {
      audioBar.style.transform = '';
      audioBar.style.opacity = '';
    }
    barClosed = false;
    navAudioBtn.classList.add('hidden');
    if (audioCta) audioCta.classList.remove('hidden');
    if (audio && playIcon && !playing) {
      audio.play().catch(() => {});
      playing = true;
      playIcon.innerHTML = ICON_PAUSE;
    }
  });

  // Scroll handler (pasivo para no bloquear el hilo principal)
  window.addEventListener('scroll', () => {
    if (!audioBar || barClosed) return;
  }, { passive: true });
</script>
