---
import Layout from '../layouts/Layout.astro';
import ProductList from '../components/ProductList.astro';

const WA_NUMBER  = '5493454928564';
const WA_MESSAGE = encodeURIComponent('Hola, vi la info en la web y quiero mi primer pedido de $60k');
const WA_URL     = `https://wa.me/${WA_NUMBER}?text=${WA_MESSAGE}`;
const WA_CATALOG = 'https://wa.me/c/5493454928564';
---

<Layout>
  <div class="min-h-screen pb-24">

    <!-- ════════════════════════════════════════
         TOP NAV
    ════════════════════════════════════════ -->
    <nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 h-16
                bg-surface-container-low/90 glass-nav shadow-sm
                border-b border-outline-variant">
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-full bg-primary-container overflow-hidden flex-shrink-0">
          <img
            src="/Logo + Punto de venta oficial + Dirección.jpeg"
            alt="Logo D y D Aromas"
            class="w-full h-full object-cover"
          />
        </div>
        <span class="text-lg font-bold text-secondary font-headline">D y D Aromas</span>
      </div>
      <a
        href={WA_CATALOG}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver catálogo en WhatsApp"
        class="p-2 hover:bg-surface-variant rounded-full transition-colors"
      >
        <span class="material-symbols-outlined text-on-surface-variant">shopping_cart</span>
      </a>
    </nav>

    <!-- ════════════════════════════════════════
         MAIN CONTENT
    ════════════════════════════════════════ -->
    <main class="relative pt-16 overflow-x-hidden">

      <!-- Decorative elements -->
      <span class="material-symbols-outlined absolute pointer-events-none opacity-80
                   text-primary text-6xl top-24 -left-4 rotate-[-12deg]"
            aria-hidden="true">flutter_dash</span>
      <span class="material-symbols-outlined absolute pointer-events-none opacity-30
                   text-secondary text-9xl top-[40%] -right-12 rotate-[15deg]"
            aria-hidden="true">eco</span>
      <span class="material-symbols-outlined absolute pointer-events-none opacity-80
                   text-primary text-4xl bottom-1/4 -left-2 rotate-[25deg]"
            aria-hidden="true">flutter_dash</span>

      <!-- ── HERO ── -->
      <section class="relative px-6 py-12 flex flex-col items-center text-center">
        <!-- Imagen hero -->
        <div class="mb-8 w-full max-w-sm aspect-video rounded-lg overflow-hidden shadow-2xl
                    border-2 border-surface-container-high relative">
          <img
            src="/Foto local desde fuera.jpeg"
            alt="Local D y D Aromas - Concordia, Entre Ríos"
            class="w-full h-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent opacity-60"></div>
        </div>

        <h1 class="text-primary text-3xl md:text-5xl font-extrabold mb-4 leading-tight font-headline">
          Punto de Venta Oficial Saphirus
          <span class="block text-on-surface text-xl md:text-2xl font-semibold mt-1">
            Concordia, Entre Ríos
          </span>
        </h1>
        <p class="text-on-surface-variant text-lg font-medium max-w-xs md:max-w-md">
          Envíos a todo el país por Andreani 🇦🇷📦🚚
        </p>

        <div class="mt-8 flex gap-4">
          <div class="flex flex-col items-center">
            <span class="text-[10px] uppercase tracking-widest text-secondary font-bold mb-1">
              Inspiración
            </span>
            <div class="h-1 w-12 bg-primary rounded-full"></div>
          </div>
        </div>
      </section>

      <!-- ── AUDIO PLAYER ── -->
      <section class="px-6 pb-8">
        <div class="max-w-lg mx-auto bg-surface-container border border-outline-variant
                    rounded-lg p-5 shadow-lg" id="audio-player-section">
          <div class="flex items-center gap-4">
            <button
              id="play-btn"
              class="flex-shrink-0 w-14 h-14 rounded-lg bg-primary flex items-center justify-center
                     shadow-lg active:scale-95 transition-transform cursor-pointer"
              aria-label="Reproducir mensaje de bienvenida"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-on-primary" viewBox="0 0 24 24" fill="currentColor" id="play-icon">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>

            <div class="flex-1 min-w-0">
              <p class="text-on-surface font-bold text-sm font-headline">Mensaje de Bienvenida</p>
              <p class="text-on-surface-variant text-xs mt-0.5">D y D Aromas · Saphirus</p>
              <div class="mt-2.5 h-1.5 bg-surface-variant rounded-full overflow-hidden">
                <div class="h-full bg-primary rounded-full transition-all duration-300" id="progress-bar" style="width:0%"></div>
              </div>
              <div class="flex justify-between text-on-surface-variant text-[10px] mt-1">
                <span id="current-time">0:00</span>
                <span id="total-time">--:--</span>
              </div>
            </div>

            <button id="mute-btn"
              class="flex-shrink-0 w-9 h-9 rounded-full bg-surface-variant hover:bg-outline-variant
                     transition-colors flex items-center justify-center"
              aria-label="Silenciar">
              <span class="material-symbols-outlined text-on-surface-variant text-xl">volume_up</span>
            </button>
          </div>

          <audio id="welcome-audio" class="hidden" preload="none">
            <source src="/audio/bienvenida.mp3" type="audio/mpeg" />
          </audio>

          <p class="text-on-surface-variant/40 text-[10px] text-center mt-3">
            Colocá tu audio en <code class="bg-surface-variant/50 px-1 rounded">public/audio/bienvenida.mp3</code>
          </p>
        </div>
      </section>

      <!-- ── BENEFICIOS MAYORISTAS ── -->
      <section class="px-6 py-12 bg-surface-container-low rounded-t-lg relative z-10">
        <h2 class="text-primary text-2xl font-extrabold mb-8 text-center font-headline">
          Beneficios Exclusivos para Mayoristas ✨
        </h2>
        <div class="grid gap-6 max-w-lg mx-auto">

          <!-- Card 1: Compra inicial -->
          <div class="bg-surface-container-high p-6 rounded-lg border-l-4 border-primary shadow-sm">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0">🛍️</span>
              <div>
                <h3 class="text-on-surface font-bold text-lg mb-1 font-headline">
                  Primera Compra Mínima: $60.000
                </h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">
                  Armá tu pedido inicial a tu gusto con toda nuestra variedad de productos.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 2: Reposición -->
          <div class="bg-surface-container-high p-6 rounded-lg border-l-4 border-secondary shadow-sm">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0">✳️</span>
              <div>
                <h3 class="text-on-surface font-bold text-lg mb-1 font-headline">
                  Reposiciones Siguientes: Mínimo $20.000
                </h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">
                  Mantené tu precio mayorista con pedidos de reposición más accesibles.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 3: Envíos -->
          <div class="bg-surface-container-high p-6 rounded-lg border-l-4 border-primary shadow-sm">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0">🚚</span>
              <div>
                <h3 class="text-on-surface font-bold text-lg mb-1 font-headline">
                  Envíos Seguros por Andreani
                </h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">
                  Te lo llevamos a tu casa o sucursal con el respaldo de la mejor logística.
                </p>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── CATÁLOGO DINÁMICO ── -->
      <ProductList />

      <!-- ── CTA SECTION ── -->
      <section class="px-6 py-12 mx-4 mb-8 bg-primary-container rounded-lg">
        <h2 class="text-on-primary-container text-2xl font-black mb-6 text-center font-headline">
          ¡Emprendé con nosotros!
        </h2>
        <div class="flex flex-col gap-4 max-w-sm mx-auto">
          <a
            href={WA_CATALOG}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full py-4
                   bg-on-surface text-surface font-extrabold rounded-full shadow-xl
                   active:scale-95 transition-transform"
          >
            <span class="text-2xl">🛍️</span> Ver Catálogo en WhatsApp
          </a>
          <a
            href={WA_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full py-4
                   bg-surface text-primary font-extrabold rounded-full shadow-xl
                   border-2 border-primary active:scale-95 transition-transform"
          >
            <span class="text-2xl">📱</span> ¡Quiero mi primer pedido!
          </a>
        </div>
      </section>

      <!-- ── CONTACTO Y UBICACIÓN ── -->
      <section class="px-6 py-12 bg-surface-container-lowest" id="contacto">
        <h2 class="text-primary text-2xl font-bold mb-8 font-headline">
          Ubicación y Datos de Contacto 📍
        </h2>

        <div class="space-y-6 mb-8 max-w-lg">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl">location_on</span>
            <div>
              <p class="text-on-surface font-semibold">Las Heras 680</p>
              <p class="text-on-surface-variant text-sm">Concordia, Entre Ríos</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl">call</span>
            <p class="text-on-surface font-semibold">+54 9 345 492-8564</p>
          </div>
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl">alternate_email</span>
            <p class="text-on-surface font-semibold">dydaromas@gmail.com</p>
          </div>
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl">photo_camera</span>
            <p class="text-on-surface font-semibold">@dydaromas.concordia</p>
          </div>
        </div>

        <!-- Mapa embebido -->
        <div class="w-full rounded-lg overflow-hidden border border-outline-variant shadow-lg aspect-video mb-8 max-w-lg">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3445.123456!2d-58.0197!3d-31.3927!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b5c8b0e8f00001%3A0x1!2sLas%20Heras%20680%2C%20Concordia%2C%20Entre%20R%C3%ADos!5e0!3m2!1ses-419!2sar!4v1710000000000"
            width="100%"
            height="100%"
            style="border:0; filter: saturate(0.6) brightness(0.85);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="D y D Aromas - Las Heras 680, Concordia, Entre Ríos"
          ></iframe>
        </div>

        <p class="text-on-surface-variant/50 text-xs text-center">
          © 2024 D y D Aromas · Distribuidores Saphirus
        </p>
      </section>

    </main>

    <!-- ════════════════════════════════════════
         BOTTOM NAV
    ════════════════════════════════════════ -->
    <footer class="fixed bottom-0 w-full z-50 flex justify-around items-center px-2 py-3
                   bg-surface-container-low/95 glass-nav rounded-t-lg
                   border-t border-outline-variant shadow-[0_-2px_10px_rgba(0,0,0,0.3)]">

      <a href="#" class="flex flex-col items-center justify-center
                         text-primary bg-primary/10 rounded-xl px-3 py-1
                         active:scale-95 transition-transform">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">home</span>
        <span class="text-[11px] font-medium">Inicio</span>
      </a>

      <a href="#catalogo" class="flex flex-col items-center justify-center
                                  text-on-surface-variant hover:text-primary
                                  active:scale-95 transition-all">
        <span class="material-symbols-outlined">menu_book</span>
        <span class="text-[11px] font-medium">Catálogo</span>
      </a>

      <a href={WA_URL} target="_blank" rel="noopener noreferrer"
         class="flex flex-col items-center justify-center
                text-on-surface-variant hover:text-primary
                active:scale-95 transition-all">
        <span class="material-symbols-outlined">chat</span>
        <span class="text-[11px] font-medium">WhatsApp</span>
      </a>

      <a href="#contacto" class="flex flex-col items-center justify-center
                                  text-on-surface-variant hover:text-primary
                                  active:scale-95 transition-all">
        <span class="material-symbols-outlined">location_on</span>
        <span class="text-[11px] font-medium">Contacto</span>
      </a>

    </footer>

  </div>
</Layout>

<!-- ════════════════════════════════════════
     AUDIO PLAYER LOGIC
════════════════════════════════════════ -->
<script>
  const audio       = document.getElementById('welcome-audio') as HTMLAudioElement | null;
  const playBtn     = document.getElementById('play-btn');
  const playIcon    = document.getElementById('play-icon');
  const progressBar = document.getElementById('progress-bar');
  const currentEl   = document.getElementById('current-time');
  const totalEl     = document.getElementById('total-time');
  const muteBtn     = document.getElementById('mute-btn');

  const ICON_PLAY  = `<path d="M8 5v14l11-7z"/>`;
  const ICON_PAUSE = `<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>`;

  let playing = false;

  const fmt = (s: number) => `${Math.floor(s/60)}:${String(Math.floor(s%60)).padStart(2,'0')}`;

  if (audio && playBtn && playIcon) {
    audio.addEventListener('loadedmetadata', () => { if (totalEl) totalEl.textContent = fmt(audio.duration); });
    audio.addEventListener('timeupdate', () => {
      const p = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      if (progressBar) progressBar.style.width = p + '%';
      if (currentEl) currentEl.textContent = fmt(audio.currentTime);
    });
    audio.addEventListener('ended', () => {
      playing = false;
      playIcon.innerHTML = ICON_PLAY;
      if (progressBar) progressBar.style.width = '0%';
    });

    playBtn.addEventListener('click', () => {
      if (playing) {
        audio.pause();
        playing = false;
        playIcon.innerHTML = ICON_PLAY;
      } else {
        audio.play().catch(() => console.info('Agregá el audio en public/audio/bienvenida.mp3'));
        playing = true;
        playIcon.innerHTML = ICON_PAUSE;
      }
    });

    muteBtn?.addEventListener('click', () => {
      audio.muted = !audio.muted;
      const icon = muteBtn.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = audio.muted ? 'volume_off' : 'volume_up';
    });
  }
</script>
